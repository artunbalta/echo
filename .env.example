# ─────────────────────────────────────────────────────────────────────────────
# ECHO environment configuration. Copy to `.env` (and `apps/web/.env.local`) and fill in.
# Nothing here is committed. Every provider is swappable; leave a key blank to use mocks.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Postgres + Auth + Storage + pgvector) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (for migrations / ML service / seed)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ── Realtime (Colyseus) ──────────────────────────────────────────────────────
REALTIME_PORT=2567
NEXT_PUBLIC_REALTIME_URL=ws://localhost:2567

# ── ML service (Python FastAPI) ──────────────────────────────────────────────
ML_PORT=8000
ML_SERVICE_URL=http://localhost:8000
# Shared secret so only the realtime/web servers can call the ML service
ML_SERVICE_TOKEN=dev-ml-token-change-me

# ── LLM (Anthropic Claude) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Strong model for sustained conversations + policy/reward judging; cheap model for ambient NPCs.
LLM_MODEL_STRONG=claude-opus-4-8
LLM_MODEL_CHEAP=claude-haiku-4-5-20251001
# Embeddings provider for persona/behavior vectors (see services/ml/echo_ml/embeddings.py)
EMBEDDINGS_PROVIDER=mock          # mock | voyage | openai
EMBEDDINGS_API_KEY=
EMBEDDINGS_DIM=256

# ── TTS narrator ─────────────────────────────────────────────────────────────
TTS_PROVIDER=mock                 # mock | elevenlabs | openai
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
OPENAI_API_KEY=

# ── Character art generation ─────────────────────────────────────────────────
ART_PROVIDER=mock                 # mock | fal | higgsfield  (degrades to mock on failure)
# Fal (REST queue API, no SDK dep). Auth header is "Key $FAL_KEY".
FAL_KEY=
FAL_MODEL=fal-ai/flux/schnell     # override per your Fal catalog (img2img models also OK)
# Higgsfield (official @higgsfield/client SDK — opt-in: `npm i @higgsfield/client -w @echo/web`).
HF_API_KEY=
HF_SECRET=
# Canonical pixel-art style anchor (path or URL). See pipeline/assets/reference/.
ART_STYLE_REFERENCE=pipeline/assets/reference/style-anchor.png
# Supabase Storage bucket for generated sprite sheets (create a PUBLIC bucket named this).
# Without Supabase, sprites fall back to inline data URLs so the flow still works locally.
ART_STORAGE_BUCKET=characters

# ── Cost controls ────────────────────────────────────────────────────────────
COST_DAILY_USD_BUDGET=25
COST_ALERT_WEBHOOK=

# ── THY brand-stand demo (/venue + /dashboard) ───────────────────────────────
# ALL optional. With none set the demo runs fully in mock mode (scripted salesperson,
# autonomous visitor sim, committed art, in-memory store). Adding a key flips that one
# subsystem to live — no code changes. (capabilities reads these at runtime.)
#   ANTHROPIC_API_KEY  → real LLM salesperson + visitor role-play     (shared with above)
#   HIGGSFIELD_API_KEY → `npm run gen:assets` generates venue art via the Higgsfield CLI
#   FAL_API_KEY        → Fal fallback art provider
#   TTS_API_KEY        → spoken salesperson (provider from TTS_PROVIDER above)
HIGGSFIELD_API_KEY=
FAL_API_KEY=
TTS_API_KEY=
# Optional model overrides for the salesperson / visitor sim:
LLM_MODEL_STRONG=claude-sonnet-4-6
LLM_MODEL_CHEAP=claude-haiku-4-5-20251001
